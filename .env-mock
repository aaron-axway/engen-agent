# .env values for END-TO-END TESTING against the local mock upstream server
# (test-scripts/mock-server/mock_server.py).
#
# To use (your real .env stays untouched):
#   1. Start the mock server:        uv run test-scripts/mock-server/mock_server.py
#   2. Start the webhook service:    ./start-webhook-service.sh --env-file .env-mock
#   3. Run the interactive driver:   ./test-scripts/test-e2e-interactive.sh
#
# All upstream URLs point at the local mock on port 9090. Any token value works
# because the mock doesn't validate auth.

# ===========================
# Server Configuration
# ===========================
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ===========================
# Database
# ===========================
DATABASE_URL=jdbc:h2:file:./data/webhook_db;DB_CLOSE_ON_EXIT=FALSE
DATABASE_USERNAME=sa
DATABASE_PASSWORD=
H2_CONSOLE_ENABLED=true

# ===========================
# Axway Amplify (mock)
# ===========================
# Inbound webhook auth — used by the test scripts when sending to /webhooks/axway
AXWAY_WEBHOOK_TOKEN=test-axway-token

# Outbound API calls (resource fetches + approval updates) → mock server
AXWAY_API_BASE_URL=http://localhost:9090
AXWAY_API_TOKEN=mock-token

# Disable JWT OAuth — static AXWAY_API_TOKEN is enough against the mock
AXWAY_OAUTH_ENABLED=false

# ===========================
# Highmark OAuth + Catalog (mock)
# ===========================
HIGHMARK_OAUTH_ENABLED=true
HIGHMARK_OAUTH_AUTH_METHOD=basic
HIGHMARK_OAUTH_TOKEN_URL=http://localhost:9090/oauth2/rest/token
HIGHMARK_OAUTH_CLIENT_ID=mock-client
HIGHMARK_OAUTH_CLIENT_SECRET=mock-secret
HIGHMARK_OAUTH_IDENTITY_DOMAIN=MockDomain
HIGHMARK_OAUTH_SCOPE=resource.READ
HIGHMARK_OAUTH_TOKEN_CACHE_MINUTES=55

HIGHMARK_CATALOG_API_ENABLED=true
HIGHMARK_CATALOG_BASE_URL=http://localhost:9090/snow/v1
HIGHMARK_CATALOG_ITEM_SYS_ID=mock-catalog-item-sys-id
HIGHMARK_DEFAULT_DATA_GOVERNANCE=Internal
HIGHMARK_DEFAULT_DG_CLASS_TAGS=Standard
HIGHMARK_DEFAULT_APPROVAL_STATE=pending
HIGHMARK_DEFAULT_NEED_BY_DAYS=30

# ===========================
# Email — disabled for E2E
# ===========================
EMAIL_ENABLED=false

# ===========================
# OAuth startup health check — don't block startup if mock is briefly down
# ===========================
OAUTH_STARTUP_HEALTH_CHECK_ENABLED=true
OAUTH_STARTUP_SHUTDOWN_ON_FAILURE=false
OAUTH_STARTUP_REQUIRED_SERVICES=highmark

# ===========================
# Event cleanup — off for testing
# ===========================
EVENT_CLEANUP_ENABLED=false

# ===========================
# Debug / payload dump
# ===========================
WEBHOOK_LOG_FILE=
WEBHOOK_DUMP_PAYLOAD=true
